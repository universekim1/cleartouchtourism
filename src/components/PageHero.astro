---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
interface Props { image: ImageMetadata; eyebrow: string; title: string; subtitle?: string; }
const { image, eyebrow, title, subtitle } = Astro.props;
---
<section class="page-hero">
  <div class="page-hero__bg">
    <Image src={image} alt="" widths={[800, 1600]} sizes="100vw" />
  </div>
  <div class="container">
    <p class="eyebrow page-hero__eyebrow">{eyebrow}</p>
    <h1 class="page-hero__title">{title}</h1>
    {subtitle && <p class="page-hero__sub">{subtitle}</p>}
  </div>
</section>
