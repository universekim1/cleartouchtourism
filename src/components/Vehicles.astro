---
/* Van (group transfers) + car (private transfers) illustration for the Airport Transfers card */
---
<svg class="vehicles" viewBox="0 0 400 275" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Van for group transfers and car for private transfers">
  <defs>
    <linearGradient id="vsky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#e9f6f9" />
      <stop offset="1" stop-color="#ffffff" />
    </linearGradient>
  </defs>

  <rect width="400" height="275" fill="url(#vsky)" />

  <!-- labels -->
  <text x="22" y="34" font-family="Inter, sans-serif" font-size="14" font-weight="800" letter-spacing="2.5" fill="#0e3a4a">GROUP</text>
  <text x="378" y="34" text-anchor="end" font-family="Inter, sans-serif" font-size="14" font-weight="800" letter-spacing="2.5" fill="#e85e3c">PRIVATE</text>

  <!-- road -->
  <rect x="0" y="190" width="400" height="85" fill="#dbe6ea" />
  <line x1="0" y1="190" x2="400" y2="190" stroke="#c3d3d9" stroke-width="2" />
  <line x1="12" y1="234" x2="388" y2="234" stroke="#aebfc7" stroke-width="4" stroke-dasharray="20 16" stroke-linecap="round" />

  <!-- VAN (group) -->
  <g>
    <ellipse cx="120" cy="192" rx="84" ry="8" fill="#0a2a43" opacity="0.12" />
    <rect x="46" y="100" width="150" height="68" rx="13" fill="#0e3a4a" />
    <rect x="46" y="150" width="150" height="9" fill="#12c0cb" />
    <rect x="60" y="112" width="42" height="26" rx="5" fill="#bfe6ec" />
    <rect x="110" y="112" width="34" height="26" rx="5" fill="#bfe6ec" />
    <rect x="152" y="112" width="34" height="26" rx="5" fill="#bfe6ec" />
    <circle cx="84" cy="168" r="18" fill="#0c2c38" /><circle cx="84" cy="168" r="7" fill="#12c0cb" />
    <circle cx="164" cy="168" r="18" fill="#0c2c38" /><circle cx="164" cy="168" r="7" fill="#12c0cb" />
  </g>

  <!-- CAR (private) -->
  <g>
    <ellipse cx="300" cy="194" rx="72" ry="7" fill="#0a2a43" opacity="0.12" />
    <path d="M234 170 v-16 q0-7 9-9 l16 0 18-22 q4-5 12-5 h34 q8 0 12 6 l14 21 14 4 q9 3 9 12 v9 q0 5-6 5 z" fill="#ff7a59" />
    <path d="M268 124 h26 q5 0 8 5 l11 18 h-58 l9 -18 q2 -5 8 -5 z" fill="#0e3a4a" opacity="0.9" />
    <circle cx="262" cy="170" r="17" fill="#0c2c38" /><circle cx="262" cy="170" r="6" fill="#ffffff" />
    <circle cx="340" cy="170" r="17" fill="#0c2c38" /><circle cx="340" cy="170" r="6" fill="#ffffff" />
  </g>
</svg>
