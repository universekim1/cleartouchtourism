---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import PageHero from "../components/PageHero.astro";
import { site } from "../data/site";
import heroImg from "../assets/images/portfolio/shot-4.jpg";

const wa = `https://wa.me/${site.whatsapp}`;

// Gallery items. `cat` sets the filter bucket — adjust freely, or drop new
// images into src/assets/images/portfolio/ and add them here.
const portfolioImgs = import.meta.glob<{ default: ImageMetadata }>("../assets/images/portfolio/*.jpg", { eager: true });
const destImgs = import.meta.glob<{ default: ImageMetadata }>("../assets/images/destinations/*.jpg", { eager: true });

const items = [
  ...Object.values(portfolioImgs).map((m, i) => ({ img: m.default, cat: i % 2 === 0 ? "events" : "portraits" })),
  ...Object.values(destImgs).map((m) => ({ img: m.default, cat: "travel" })),
];

// Pre-render a larger version of each image for the lightbox.
const fulls = await Promise.all(items.map((it) => getImage({ src: it.img, width: 1600 })));

const cats = [
  { key: "all",       label: "All work" },
  { key: "events",    label: "Events & Parties" },
  { key: "portraits", label: "Portraits" },
  { key: "travel",    label: "Travel & Destinations" },
];
---
<Base title="Portfolio — Clear Touch Tourism & Services"
      description="A gallery of recent photography and videography by Clear Touch — events, portraits, studio and travel across Qatar.">
  <Header active="portfolio" />

  <PageHero image={heroImg} eyebrow="Our work"
    title="Portfolio"
    subtitle="A selection of recent shoots across Qatar — events, portraits, studio and travel. Tap any image to view it full-size." />

  <section class="section section--cream">
    <div class="container">
      <div class="pf-filters" role="tablist">
        {cats.map((c, i) => (
          <button class={`pf-filter${i === 0 ? " is-active" : ""}`} data-filter={c.key} type="button">{c.label}</button>
        ))}
      </div>

      <div class="pf-gallery" id="pfGallery">
        {items.map((it, i) => (
          <button class="pf-item" data-cat={it.cat} data-full={fulls[i].src} type="button" aria-label="View image full size">
            <Image src={it.img} alt={`Clear Touch photography ${i + 1}`}
                   widths={[400, 800]} sizes="(max-width:560px) 100vw, (max-width:900px) 50vw, 340px" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="container">
      <div class="cta-band">
        <h2>Like what you see?</h2>
        <p>Book your own shoot, or follow along for more of our latest work.</p>
        <div class="hero__cta">
          <a class="btn btn--white" href="/photography#packages">See packages</a>
          <a class="btn btn--ghost" href={site.instagram} target="_blank" rel="noopener">Instagram</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-label="Image viewer">
    <button class="lightbox__close" type="button" aria-label="Close">&times;</button>
    <button class="lightbox__nav lightbox__prev" type="button" aria-label="Previous">&lsaquo;</button>
    <img class="lightbox__img" id="lightboxImg" src="" alt="Portfolio image" />
    <button class="lightbox__nav lightbox__next" type="button" aria-label="Next">&rsaquo;</button>
  </div>

  <Footer />

  <script>
    const gallery = document.getElementById("pfGallery");
    const items = Array.from(gallery ? gallery.querySelectorAll<HTMLButtonElement>(".pf-item") : []);
    const filters = Array.from(document.querySelectorAll<HTMLButtonElement>(".pf-filter"));
    const lb = document.getElementById("lightbox");
    const lbImg = document.getElementById("lightboxImg") as HTMLImageElement | null;

    // ---- filtering ----
    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        filters.forEach((b) => b.classList.remove("is-active"));
        btn.classList.add("is-active");
        const f = btn.dataset.filter;
        items.forEach((it) => {
          it.style.display = f === "all" || it.dataset.cat === f ? "" : "none";
        });
      });
    });

    // ---- lightbox ----
    let visible: HTMLButtonElement[] = [];
    let idx = 0;
    const show = () => {
      const it = visible[idx];
      if (it && lbImg) lbImg.src = it.dataset.full || it.querySelector("img")?.src || "";
    };
    const open = (it: HTMLButtonElement) => {
      visible = items.filter((el) => el.style.display !== "none");
      idx = Math.max(0, visible.indexOf(it));
      show();
      lb?.classList.add("is-open");
      lb?.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    };
    const close = () => {
      lb?.classList.remove("is-open");
      lb?.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    };
    const step = (d: number) => { idx = (idx + d + visible.length) % visible.length; show(); };

    items.forEach((it) => it.addEventListener("click", () => open(it)));
    lb?.querySelector(".lightbox__close")?.addEventListener("click", close);
    lb?.querySelector(".lightbox__prev")?.addEventListener("click", (e) => { e.stopPropagation(); step(-1); });
    lb?.querySelector(".lightbox__next")?.addEventListener("click", (e) => { e.stopPropagation(); step(1); });
    lb?.addEventListener("click", (e) => { if (e.target === lb) close(); });
    document.addEventListener("keydown", (e) => {
      if (!lb?.classList.contains("is-open")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") step(-1);
      if (e.key === "ArrowRight") step(1);
    });
  </script>
</Base>
