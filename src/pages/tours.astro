---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import PageHero from "../components/PageHero.astro";
import { site, tours, destinations } from "../data/site";
import heroImg from "../assets/images/destinations/desert-safari.jpg";

const destImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/destinations/*.jpg", { eager: true });
const destImg = (slug: string) => destImages[`../assets/images/destinations/${slug}.jpg`]?.default;
const wa = `https://wa.me/${site.whatsapp}`;
---
<Base title="Tours & Experiences — Clear Touch Tourism & Services"
      description="Hand-crafted Qatar tours — desert safaris, Doha city tours, dhow cruises, island escapes, visa help and airport transfers.">
  <Header active="tours" />

  <PageHero image={heroImg} eyebrow="Tours & experiences"
    title="Explore Qatar your way"
    subtitle="From golden dunes to glittering skylines — ready-made adventures or a trip tailored just for you, with a trusted local team." />

  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What we offer</p>
        <h2 class="h-display">Our signature tours</h2>
        <p>Pick a signature experience below, or tell us your dream and we'll build it around you.</p>
      </div>
      <div class="grid-3">
        {tours.map((t) => {
          const img = destImg(t.img);
          return (
            <a class="tour-card" href={`/tours/${t.slug}`}>
              <div class="tour-card__media">
                {img && <Image src={img} alt={t.name} widths={[400, 700]} sizes="(max-width:900px) 50vw, 360px" />}
                <span class="tour-card__price">{t.groupSize}</span>
              </div>
              <div class="tour-card__body">
                <h3>{t.name}</h3>
                <p>{t.tagline}</p>
                <div class="tour-card__meta">
                  <span><Icon name="clock" size={15} /> {t.duration}</span>
                  <span class="tour-card__more">View details <Icon name="arrow" size={15} /></span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--navy">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Where we'll take you</p>
        <h2 class="h-display">Popular destinations</h2>
        <p>Nine signature locations across Qatar, each with its own story to tell.</p>
      </div>
      <div class="dest-grid">
        {destinations.map((d) => {
          const img = destImg(d.slug);
          return (
            <a class="dest" href="/contact">
              {img && <Image src={img} alt={d.name} widths={[400, 700, 1000]} sizes="(max-width:560px) 92vw, (max-width:900px) 46vw, 360px" />}
              <div class="dest__label"><h3>{d.name}</h3><span>{d.tag}</span></div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="cta-band">
        <h2>Ready to experience Qatar?</h2>
        <p>Tell us your dates and what you'd love to see — we'll craft the perfect itinerary.</p>
        <div class="hero__cta">
          <a class="btn btn--white" href={wa}>Chat on WhatsApp</a>
          <a class="btn btn--ghost" href="/contact">Contact us</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
