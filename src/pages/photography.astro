---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import PageHero from "../components/PageHero.astro";
import { site, photoServices, photoPackages, photoAddons, photoProcess } from "../data/site";
import heroImg from "../assets/images/portfolio/portrait-maternity-couple.jpg";

const portfolio = Object.values(
  import.meta.glob<{ default: ImageMetadata }>("../assets/images/portfolio/*.jpg", { eager: true })
).map((m) => m.default);
const destShots = Object.values(
  import.meta.glob<{ default: ImageMetadata }>("../assets/images/destinations/*.jpg", { eager: true })
).map((m) => m.default);
const gallery = [...portfolio, ...destShots];
const wa = `https://wa.me/${site.whatsapp}`;
---
<Base title="Photography & Videography in Doha, Qatar | Clear Touch"
      description="Doha-based photography and videography studio — travel and destination imagery, cinematic films and reels, weddings, events and portraits.">
  <Header active="photography" />

  <PageHero image={heroImg} eyebrow="Photography & video in Doha, Qatar"
    title="Memories, beautifully made"
    subtitle="A Doha-based creative studio capturing travel, events and brands across Qatar — the same crew that knows every location on your tour." />

  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What we shoot</p>
        <h2 class="h-display">Creative services</h2>
        <p>Stills and motion, on location anywhere in Qatar.</p>
      </div>
      <div class="grid-3">
        {photoServices.map((p) => (
          <article class="card">
            <div class="card__icon"><Icon name={p.icon} /></div>
            <h3>{p.title}</h3>
            <p>{p.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SESSION TYPES ============
       Prices & direct booking intentionally removed 2026-07-04 while photography
       is added to the company CR (registered activity). Data (prices/cal CTAs)
       kept in site.ts — restore the price block + Cal.com CTAs once the CR
       amendment + Ministry of Culture studio licence are approved. -->
  <section class="section section--navy" id="packages">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What we offer</p>
        <h2 class="h-display">Ways to work together</h2>
        <p>From outdoor and studio sessions to full event, wedding and brand coverage — every shoot includes professional editing and a private online gallery. Tell us about your day and we'll tailor the details to fit.</p>
      </div>
      <div class="pkg-grid">
        {photoPackages.map((p) => (
          <article class={`pkg-card${p.featured ? " pkg-card--featured" : ""}`}>
            {p.badge && <span class="pkg-badge">{p.badge}</span>}
            <h3>{p.name}</h3>
            <p class="pkg-tagline">{p.tagline}</p>
            <ul class="pkg-features">
              {p.features.map((f) => (
                <li><Icon name="check" size={16} /><span>{f}</span></li>
              ))}
            </ul>
            <a class={`btn pkg-cta ${p.featured ? "btn--gold" : "btn--outline"}`} href="/contact">Enquire <Icon name="arrow" size={16} /></a>
          </article>
        ))}
      </div>
      <p class="pkg-note"><strong>Add-ons:</strong> {photoAddons.join("  ·  ")}</p>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="section section--cream">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">How it works</p>
        <h2 class="h-display">From first message to final gallery</h2>
        <p>A calm, guided process — you show up, we handle the rest.</p>
      </div>
      <div class="process-grid">
        {photoProcess.map((s) => (
          <div class="process-step">
            <span class="process-num">{s.step}</span>
            <h3>{s.title}</h3>
            <p>{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ PORTFOLIO ============ -->
  <section class="section section--navy">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Selected work</p>
        <h2 class="h-display">Portfolio</h2>
        <p>A glimpse of recent shoots across Qatar.</p>
      </div>
      <div class="gallery">
        {gallery.map((img, i) => (
          <Image src={img} alt={`Clear Touch photography ${i + 1}`}
                 widths={[400, 640, 900]} sizes="(max-width:900px) 46vw, 360px" />
        ))}
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="cta-band">
        <h2>Have a shoot in mind?</h2>
        <p>Weddings, events, brand campaigns or travel content — let's create something beautiful.</p>
        <div class="hero__cta">
          <a class="btn btn--white" href={wa}>Enquire about a shoot</a>
          <a class="btn btn--ghost" href="/contact">Contact us</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
