---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import Vehicles from "../components/Vehicles.astro";
import Globe from "../components/Globe.astro";
import { site, offerings, photoServices, destinations, why, testimonials } from "../data/site";

import hero from "../assets/images/hero.jpg";
import about from "../assets/images/about.jpg";

const destImages = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/destinations/*.jpg", { eager: true });
const portfolio = Object.values(
  import.meta.glob<{ default: ImageMetadata }>("../assets/images/portfolio/*.jpg", { eager: true })
).map((m) => m.default);

const destImg = (slug: string) =>
  destImages[`../assets/images/destinations/${slug}.jpg`]?.default;

const wa = `https://wa.me/${site.whatsapp}`;
---
<Base>
  <Header active="home" />

  <!-- ============ HERO ============ -->
  <section class="hero" id="home">
    <div class="hero__bg">
      <video
        class="hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster="/hero-poster.jpg"
        data-src-wide="/hero-wide.mp4"
        data-src-tall="/hero.mp4"
      ></video>
      <Image src={hero} alt="Qatar tours and photography" widths={[800, 1400, 2000]} sizes="100vw" class="hero__fallback" />
    </div>
    <script is:inline>
      (function () {
        var v = document.querySelector(".hero__video");
        if (!v) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var wide = window.matchMedia("(min-width: 900px)").matches;
        var s = document.createElement("source");
        s.src = wide ? v.dataset.srcWide : v.dataset.srcTall;
        s.type = "video/mp4";
        v.appendChild(s);
        v.load();
      })();
    </script>
    <div class="container">
      <div class="hero__inner">
        <span class="badge">★ Qatar's trusted tours & creative studio</span>
        <h1>Discover Qatar.<br />Capture It <span class="gold-word">Forever.</span></h1>
        <p class="hero__lede">
          Hand-crafted desert safaris, Doha city tours and dhow cruises — plus award-quality
          photography and videography to remember every moment. One trusted team, two ways to wow.
        </p>
        <div class="hero__cta">
          <a class="btn btn--gold" href="/tours">Explore Tours <Icon name="arrow" size={18} /></a>
          <a class="btn btn--whatsapp" href={wa}>Chat on WhatsApp</a>
        </div>

        <form class="booking" onsubmit="return false">
          <div class="booking__field">
            <label for="exp">What do you need</label>
            <select id="exp">
              <option>Desert Safari</option>
              <option>Doha City Tour</option>
              <option>Dhow Cruise</option>
              <option>Photography Session</option>
              <option>Video / Reel Shoot</option>
            </select>
          </div>
          <div class="booking__field">
            <label for="guests">Guests</label>
            <select id="guests"><option>2 Guests</option><option>1 Guest</option><option>3–4 Guests</option><option>5+ Guests</option></select>
          </div>
          <div class="booking__submit">
            <a class="btn btn--gold" href={site.calUrl} data-cal-namespace="book" data-cal-link={site.calLink} data-cal-config='{"layout":"month_view"}'>Check live availability — pick a date &amp; time →</a>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- ============ TOURS / OFFERINGS ============ -->
  <section class="section section--cream" id="tours">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What we offer</p>
        <h2 class="h-display">Unforgettable Experiences</h2>
        <p>From golden dunes to glittering skylines — pick your perfect Qatar adventure.</p>
      </div>
      <div class="grid-3">
        {offerings.map((o) => {
          const img = o.img ? destImg(o.img) : undefined;
          return (
            <article class="offer-card">
              <div class="offer-card__media">
                {o.vehicles
                  ? <Vehicles />
                  : (img && <Image src={img} alt={o.title} widths={[400, 700]} sizes="(max-width:900px) 50vw, 360px" />)}
              </div>
              <div class="offer-card__body">
                <div class="card__icon"><Icon name={o.icon} /></div>
                <h3>{o.title}</h3>
                <p>{o.text}</p>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============ PHOTOGRAPHY & VIDEO PILLAR (equal billing) ============ -->
  <section class="section section--navy" id="photography">
    <div class="container">
      <div class="split">
        <div class="photo-mosaic">
          {portfolio.slice(0, 5).map((p, i) => (
            <Image src={p} alt={`Clear Touch photography ${i + 1}`} class={i === 0 ? "tall" : ""}
                   widths={[400, 700]} sizes="(max-width:900px) 50vw, 280px" />
          ))}
        </div>
        <div>
          <p class="eyebrow">Photography & Video</p>
          <h2 class="h-display">Memories, beautifully made</h2>
          <p style="color:var(--ink-soft); margin-top:14px;">
            Our other half is a full creative studio. Doha-based photographers and filmmakers
            capturing travel, events and brands across Qatar — the same crew that knows every
            location on your tour.
          </p>
          <div class="feature-list">
            {photoServices.map((p) => (
              <div class="feature">
                <div class="feature__icon"><Icon name={p.icon} size={22} /></div>
                <div><h4>{p.title}</h4><p>{p.text}</p></div>
              </div>
            ))}
          </div>
          <div class="hero__cta" style="margin-top:30px;">
            <a class="btn btn--gold" href="/photography#packages">Book a Shoot <Icon name="arrow" size={18} /></a>
            <a class="btn btn--outline" href="/portfolio">View Portfolio</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ JOURNEY / GLOBE BAND ============ -->
  <section class="journey" id="journey" aria-label="Your Qatar journey">
    <div class="container journey__inner">
      <div class="journey__copy">
        <p class="eyebrow eyebrow--light">Your journey starts here</p>
        <h2 class="h-display">It all begins in <span class="gold-word">Doha</span>.</h2>
        <p class="journey__lede">
          Wherever you're flying from, your Qatar adventure lands right here on the shores of
          the Arabian Gulf. From this one city we'll take you to golden dunes, glittering
          skylines and hidden pearls — camera in hand, every moment captured.
        </p>
        <div class="journey__cta">
          <a class="btn btn--gold" href="/tours">Explore Tours <Icon name="arrow" size={18} /></a>
          <a class="btn btn--ghost" href={wa}>Plan my trip</a>
        </div>
      </div>
      <div class="journey__globe">
        <Globe />
      </div>
    </div>
  </section>

  <!-- ============ DESTINATIONS GALLERY ============ -->
  <section class="section section--cream" id="destinations">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Where we'll take you</p>
        <h2 class="h-display">Popular Destinations</h2>
        <p>Nine signature locations across Qatar, each with its own story to tell.</p>
      </div>
      <div class="dest-grid">
        {destinations.map((d) => {
          const img = destImg(d.slug);
          return (
            <div class="dest" data-flip>
              <div class="dest__inner">
                <div class="dest__face dest__front">
                  {img && <Image src={img} alt={d.name} widths={[400, 700]} sizes="(max-width:900px) 50vw, 360px" />}
                  <div class="dest__label"><h3>{d.name}</h3><span>{d.tag}</span></div>
                  <span class="dest__flip-hint"><Icon name="arrow" size={16} /></span>
                </div>
                <div class="dest__face dest__back">
                  <span class="dest__tag">{d.tag}</span>
                  <h3>{d.name}</h3>
                  <a class="btn btn--gold" href={`/tours/${d.tour}`}>View tour <Icon name="arrow" size={16} /></a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============ WHY US ============ -->
  <section class="section section--cream" id="why">
    <div class="container">
      <div class="split split--reverse">
        <div class="media-frame">
          <Image src={about} alt="Doha skyline at dusk" widths={[600, 1000]} sizes="(max-width:900px) 100vw, 540px" />
          <div class="stat-badge"><strong>{site.yearsBadge}</strong><span>years creating Qatar memories</span></div>
        </div>
        <div>
          <p class="eyebrow">Why Clear Touch</p>
          <h2 class="h-display">Travel with the experts who care</h2>
          <p style="color:var(--ink-soft); margin-top:14px;">
            We're a fully licensed Qatar tour operator and creative studio obsessed with one thing —
            giving you an effortless, jaw-dropping experience from the first click to the last sunset.
          </p>
          <div class="feature-list">
            {why.map((w) => (
              <div class="feature">
                <div class="feature__icon"><Icon name={w.icon} size={22} /></div>
                <div><h4>{w.title}</h4><p>{w.text}</p></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="section section--navy" id="reviews">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Loved by travellers</p>
        <h2 class="h-display">What our guests say</h2>
        <p>Rated {site.rating}/5 across Google, TripAdvisor & GetYourGuide.</p>
      </div>
      <div class="tgrid">
        {testimonials.map((t) => (
          <div class="tcard">
            <div class="stars">★★★★★</div>
            <blockquote>“{t.quote}”</blockquote>
            <div class="tcard__who">
              <div class="avatar">{t.initial}</div>
              <div><b>{t.name}</b><span>{t.place}</span></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA BAND ============ -->
  <section class="section section--cream" id="contact">
    <div class="container">
      <div class="cta-band">
        <h2>Ready to experience Qatar?</h2>
        <p>Tell us what you're dreaming of — a tour, a photo shoot, or both — and we'll build it around you.</p>
        <div class="hero__cta">
          <a class="btn btn--white" href={wa}>Chat on WhatsApp</a>
          <a class="btn btn--ghost" href={`mailto:${site.email}`}>Email Us</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    // Destination flip cards: hover flips on desktop (CSS); tap flips on touch.
    const touch = window.matchMedia("(hover: none)").matches;
    document.querySelectorAll(".dest[data-flip]").forEach((card) => {
      card.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).closest("a")) return; // let the CTA link work
        if (touch) card.classList.toggle("is-flipped");
      });
    });
  </script>
</Base>
