---
import "../styles/global.css";
import { site } from "../data/site";
interface Props { title?: string; description?: string; }
const {
  title = `${site.fullName} — Doha Tourism, Photography & Videography`,
  description = "Qatar's trusted tour operator and creative studio. Hand-crafted Doha tours, desert safaris and dhow cruises, plus professional travel photography and videography.",
} = Astro.props;
---
<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&family=Playfair+Display:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
